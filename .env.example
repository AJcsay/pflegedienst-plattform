# Optional — Build-Time-Variablen für die Frontend-Integrationen.
# Werden während `vite build` als import.meta.env.* eingelesen.
# Für lokale Entwicklung als .env in den Projekt-Root kopieren.

# Zeeg-Buchungs-URL für die Erstberatungs-Termine
# Beispiel: https://zeeg.me/curamain/erstberatung
VITE_ZEEG_URL=

# Trustindex-Widget-ID (Google-Reviews)
# https://www.trustindex.io – nach Setup → Widget-ID kopieren
VITE_TRUSTINDEX_WIDGET_ID=

# Direkter Google-Review-Link (für CTA solange noch keine Reviews vorhanden)
# Beispiel: https://g.page/r/CcXXXXXXXXX/review
VITE_GOOGLE_REVIEW_URL=
