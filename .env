# Build-Time-Variablen für die Frontend-Integrationen.
# Werden während `vite build` als import.meta.env.* eingelesen.

# Zeeg-Buchungs-URL für Erstberatungs-Termine
VITE_ZEEG_URL=https://zeeg.me/curamain

# Trustindex-Widget-ID (Google-Reviews) — folgt später
VITE_TRUSTINDEX_WIDGET_ID=

# Direkter Google-Review-Link für CTA — folgt später
VITE_GOOGLE_REVIEW_URL=
